{
  "name": "helfi-hav",
  "version": "1.0.0",
  "description": "Search monitoring for HELfi projects with elastic-proxy.",
  "type": "module",
  "main": "dist/app.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "node --experimental-strip-types --test --test-concurrency=1 --experimental-test-coverage --test-force-exit test/**/*.test.ts",
    "test:coverage": "mkdir -p coverage && node --experimental-strip-types --test --test-concurrency=1 --experimental-test-coverage --test-reporter=lcov --test-reporter-destination coverage/lcov.info --test-force-exit test/**/*.test.ts",
    "start": "NODE_OPTIONS=--experimental-strip-types node src/server.ts",
    "typecheck": "tsc",
    "dev": "NODE_OPTIONS=--experimental-strip-types node --watch src/server.ts",
    "info": "NODE_OPTIONS=--experimental-strip-types node src/bin/hav-print-routes.ts",
    "lint": "biome check --write src/",
    "lint:check": "biome check src/",
    "hav:init-mongodb": "node --experimental-strip-types src/bin/hav-init-mongodb.ts",
    "hav:update-subscription-length": "node --experimental-strip-types src/bin/hav-update-subscription-length.ts",
    "hav:populate-queue": "node --experimental-strip-types src/bin/hav-populate-queue.ts",
    "hav:send-queue": "node --experimental-strip-types src/bin/hav-send-queue.ts",
    "hav:test-sms-sending": "node --experimental-strip-types src/bin/hav-test-sms-sending.ts",
    "hav:test-email-templates": "node --experimental-strip-types src/bin/hav-test-email-templates.ts",
    "hav:test-all-templates": "node --experimental-strip-types src/bin/hav-test-all-templates.ts",
    "hav:run-dialogi-test-server": "node --experimental-strip-types src/bin/hav-dialogi-test-server.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/mongodb": "^9.0.2",
    "@fastify/sensible": "^6.0.3",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@immobiliarelabs/fastify-sentry": "^9.0.1",
    "@sinclair/typebox": "^0.34.41",
    "axios": "^1.6.7",
    "dotenv": "^16.3.1",
    "fastify": "^5.6.2",
    "fastify-mailer": "^2.3.1",
    "fastify-plugin": "^5.1.0",
    "google-libphonenumber": "^3.2.44",
    "jsdom": "^24.0.0",
    "minimist": "^1.2.8",
    "nodemailer": "^8.0.5",
    "sprightly": "^2.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/jsdom": "^21.1.6",
    "@types/minimist": "^1.2.5",
    "@types/node": "^24.9.2",
    "@types/nodemailer": "^6.4.14",
    "concurrently": "^8.2.2",
    "fastify-tsconfig": "^3.0.0",
    "typescript": "^5.2.2"
  }
}
