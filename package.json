{
  "name": "helfi-hav",
  "version": "1.0.0",
  "description": "Search monitoring for HELfi projects with elastic-proxy.",
  "type": "module",
  "main": "src/app.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "node --test --test-concurrency=1 --experimental-test-coverage --test-force-exit test/**/*.test.ts",
    "test:coverage": "mkdir -p coverage && node --test --test-concurrency=1 --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-reporter=spec --test-reporter-destination=stdout --test-force-exit test/**/*.test.ts",
    "start": "node --import ./src/instrument.ts src/server.ts",
    "typecheck": "tsc",
    "dev": "node --watch --import ./src/instrument.ts src/server.ts",
    "lint": "biome check --write src/",
    "lint:check": "biome check src/",
    "hav:init-mongodb": "node --import ./src/instrument.ts src/bin/hav-init-mongodb.ts",
    "hav:update-subscription-length": "node --import ./src/instrument.ts src/bin/hav-update-subscription-length.ts",
    "hav:populate-queue": "node --import ./src/instrument.ts src/bin/hav-populate-queue.ts",
    "hav:send-queue": "node --import ./src/instrument.ts src/bin/hav-send-queue.ts",
    "hav:test-sms-sending": "node --import ./src/instrument.ts src/bin/hav-test-sms-sending.ts",
    "hav:test-email-templates": "node --import ./src/instrument.ts src/bin/hav-test-email-templates.ts",
    "hav:test-all-templates": "node --import ./src/instrument.ts src/bin/hav-test-all-templates.ts",
    "hav:run-dialogi-test-server": "node --import ./src/instrument.ts src/bin/hav-dialogi-test-server.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/mongodb": "^9.0.2",
    "@fastify/sensible": "^6.0.3",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sentry/node": "^10.12.0",
    "@sinclair/typebox": "^0.34.41",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.1.0",
    "google-libphonenumber": "^3.2.44",
    "jsdom": "^24.0.0",
    "nodemailer": "^8.0.5",
    "sprightly": "^2.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/jsdom": "^21.1.6",
    "@types/node": "^24.9.2",
    "@types/nodemailer": "^6.4.14",
    "fastify-tsconfig": "^3.0.0",
    "typescript": "^6.0.3"
  }
}
