{
  "extends": "fastify-tsconfig",
  "compilerOptions": {
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "outDir": "dist",
    "sourceMap": true,
    "target": "ES2020"
  },
  "include": ["src/**/*.ts"],
}

